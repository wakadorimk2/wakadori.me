# Project-local command policy for wakadori.me.
# Keep durable behavioral guidance in AI_GUIDE.md.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Destructive history/worktree reset is not allowed for this repo.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Deleting untracked files is not allowed without a separate human action.",
    match = [
        "git clean -fd",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "forbidden",
    justification = "Discarding local file changes is not allowed for this repo.",
    match = [
        "git checkout -- AI_GUIDE.md",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Recursive forced deletion is not allowed for this repo.",
    match = [
        "rm -rf .codex",
    ],
)

prefix_rule(
    pattern = ["rm", "-fr"],
    decision = "forbidden",
    justification = "Recursive forced deletion is not allowed for this repo.",
    match = [
        "rm -fr .codex",
    ],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Commits should be reviewed before recording repository history.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing changes modifies remote state.",
)

prefix_rule(
    pattern = ["git", "tag"],
    decision = "prompt",
    justification = "Tags affect release/history state and need review.",
)

prefix_rule(
    pattern = ["git", "rebase"],
    decision = "prompt",
    justification = "Rebase rewrites local history and needs review.",
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "prompt",
    justification = "Reset can discard or rewrite worktree/index state.",
)

prefix_rule(
    pattern = ["gh", "pr"],
    decision = "prompt",
    justification = "PR operations can publish or change external GitHub state.",
)

prefix_rule(
    pattern = ["gh", "issue"],
    decision = "prompt",
    justification = "Issue operations can publish or change external GitHub state.",
)

prefix_rule(
    pattern = ["npm", ["install", "i"]],
    decision = "prompt",
    justification = "Dependency installation can change lockfiles and use the network.",
)

prefix_rule(
    pattern = ["pnpm", ["install", "add"]],
    decision = "prompt",
    justification = "Dependency installation can change lockfiles and use the network.",
)

prefix_rule(
    pattern = ["yarn", ["install", "add"]],
    decision = "prompt",
    justification = "Dependency installation can change lockfiles and use the network.",
)

prefix_rule(
    pattern = ["bun", ["install", "add"]],
    decision = "prompt",
    justification = "Dependency installation can change lockfiles and use the network.",
)

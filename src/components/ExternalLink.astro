---
interface Props {
  href: string;
  label: string;
  class?: string;
}

const { href, label, class: className } = Astro.props;
---

<a class={className} href={href} target="_blank" rel="noopener noreferrer">
  <span>{label}</span>
  <span aria-hidden="true">↗</span>
  <span class="sr-only">（新しいタブで開きます）</span>
</a>
